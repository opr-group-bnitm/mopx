params {
    // drafting parameters
    contigs = null
    reads = null
    reference = null
    draft = null
    basecounts = null
    hairpin = null

    out_dir = "output"
    draft_name = "draft"

    medaka_consensus_model = "/Users/nils.petersen/dev/mpx/mpox_analysis/workflow/r1041_e82_400bps_hac_v4.1.0_model_pt.tar.gz"
    min_coverage = 20
    medaka_variant_minqual = 10 // So far only for terminal hairpin

    sniffles_predraft_min_variant_allele_fraction = 0.8
    sniffles_predraft_min_support = 5
    sniffles_predraft_min_sv_len = 20

    canu_genome_size = "200k"
    canu_min_read_length = 500
    canu_min_overlap_length = 500
    canu_stop_on_low_coverage = 1
    canu_min_input_coverage = 2

    flye_genome_size = 200000

    contigs_cluster_cdhit_min_similarity = 0.99
    contigs_cluster_cdhit_wordlen = 9

    readmap_min_secondary2primary_ratio = 0.8
    readmap_max_secondary = 3

    
}


profiles {
    // the "standard" profile is used implicitely by nextflow
    // if no other profile is given on the CLI
    standard {
        docker {
            enabled = true
            // this ensures container is run as host user and group, but
            //    also adds host user to the within-container group
            runOptions = "--user \$(id -u):\$(id -g) --group-add 100"
        }
    }
}


process {
    withLabel:common {
        container = "mopx_common:0.0.1"
        memory = '2G'
    }
    withLabel:structural_variants {
        container = "mopx_structural_variants:0.0.1"
    }
    withLabel:medaka {
        container = "mopx_medaka:0.0.1"
        memory = '30G'
    }
    withLabel:flye {
        container = "mopx_flye:0.0.1"
    }
    withLabel:canu {
        container = "mopx_canu:0.0.1"
    }
}
